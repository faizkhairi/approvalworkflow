// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url is intentionally omitted — connection string goes in prisma.config.ts (Prisma 7)
}

// ============================================================
// AUTH MODELS (NextAuth v5 + @auth/prisma-adapter)
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for OAuth-only users

  accounts          Account[]
  sessions          Session[]
  orgMembers        OrgMember[]
  submittedRequests Request[]      @relation("SubmittedRequests")
  auditLogs         AuditLog[]     @relation("AuditLogActor")
  notifications     Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// ORG MODELS (Multi-tenancy)
// ============================================================

model Org {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique // URL-safe identifier — enforce lowercase in application layer
  logoUrl String?

  members   OrgMember[]
  workflows Workflow[]
  requests  Request[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrgMember {
  id     String  @id @default(cuid())
  orgId  String
  userId String
  role   OrgRole @default(MEMBER)

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

// ============================================================
// WORKFLOW TEMPLATE MODELS
// ============================================================

model Workflow {
  id          String  @id @default(cuid())
  orgId       String
  name        String // "Leave Request", "Procurement Approval"
  description String? @db.Text
  category    String?
  isActive    Boolean @default(true)
  formSchema  Json    @default("[]") // array of FormField definitions

  steps    WorkflowStep[]
  requests Request[]
  org      Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([orgId, isActive])
}

model WorkflowStep {
  id            String        @id @default(cuid())
  workflowId    String
  order         Int // 1-based sequential
  name          String // "Line Manager", "Finance Review"
  approvalMode  ApprovalMode  @default(ANY) // ANY = one approver sufficient; ALL = everyone must approve
  approverType  ApproverType  @default(USER)
  approverIds   String[] // userId[] or role name[]
  timeoutHours  Int?
  timeoutAction TimeoutAction @default(ESCALATE)
  escalateTo    String? // userId to escalate to on timeout

  workflow     Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  requestSteps RequestStep[]

  @@unique([workflowId, order])
  @@index([workflowId])
}

// ============================================================
// REQUEST LIFECYCLE MODELS
// ============================================================

model Request {
  id          String        @id @default(cuid())
  orgId       String
  workflowId  String
  submitterId String
  title       String
  status      RequestStatus @default(PENDING)
  formData    Json          @default("{}") // submitted form values keyed by field name
  currentStep Int           @default(1)

  steps       RequestStep[]
  auditLogs   AuditLog[]

  completedAt DateTime?
  cancelledAt DateTime?

  org       Org      @relation(fields: [orgId], references: [id])
  workflow  Workflow @relation(fields: [workflowId], references: [id])
  submitter User     @relation("SubmittedRequests", fields: [submitterId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([submitterId])
  @@index([orgId, workflowId])
}

model RequestStep {
  id             String        @id @default(cuid())
  requestId      String
  workflowStepId String
  stepOrder      Int
  status         StepStatus    @default(PENDING)

  // Approver snapshotted at request creation time — not re-resolved on activation
  // This prevents retroactive approver changes from affecting in-flight requests
  assignedTo  String? // userId
  decidedById String? // userId who made the decision
  decision    StepDecision?
  comment     String?   @db.Text // required on REJECTED
  decidedAt   DateTime?
  dueAt       DateTime? // set when step becomes ACTIVE

  request      Request      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  workflowStep WorkflowStep @relation(fields: [workflowStepId], references: [id])

  @@index([requestId, stepOrder])
  @@index([assignedTo, status])
}

// ============================================================
// AUDIT + NOTIFICATIONS
// ============================================================

// Append-only audit trail — NEVER run UPDATE or DELETE on this table.
// Financial/compliance immutability principle: the full history must be preserved.
model AuditLog {
  id        String  @id @default(cuid())
  requestId String
  actorId   String? // null = system action (e.g. timeout escalation)
  action    String // "SUBMITTED", "APPROVED_STEP_1", "REJECTED", "ESCALATED", "CANCELLED"
  detail    Json?
  ip        String?
  userAgent String?

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actor   User?   @relation("AuditLogActor", fields: [actorId], references: [id])

  createdAt DateTime @default(now())

  @@index([requestId, createdAt])
  @@index([actorId])
}

model Notification {
  id      String  @id @default(cuid())
  userId  String
  title   String
  body    String
  link    String?
  isRead  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ============================================================
// ENUMS
// ============================================================

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum ApprovalMode {
  ANY // one approver is sufficient (first to approve advances the step)
  ALL // all assigned approvers must approve
}

enum ApproverType {
  USER // specific user IDs
  ROLE // role-based; resolved from OrgMember.role at request creation time
}

enum TimeoutAction {
  ESCALATE
  AUTO_APPROVE
  AUTO_REJECT
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  CANCELLED
}

enum StepStatus {
  PENDING   // waiting for a preceding step to complete
  ACTIVE    // current step — awaiting approver decision
  APPROVED
  REJECTED
  SKIPPED
  ESCALATED
}

enum StepDecision {
  APPROVED
  REJECTED
}
